# ─── Redis ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=100
REDIS_SOCKET_TIMEOUT=5.0
REDIS_SOCKET_CONNECT_TIMEOUT=5.0

# ─── Workers ────────────────────────────────────────────
MAX_CONCURRENT_BROWSERS=8
JOB_TIMEOUT_SECONDS=120

# ─── Cache ──────────────────────────────────────────────
# Keep CACHE_TTL_SECONDS >= CURSOR_TTL_SECONDS so paginated clients walking
# signed cursors keep hitting the cache instead of triggering fresh scrapes
# that may return shifted data. Startup logs WARN when this invariant breaks.
CACHE_TTL_SECONDS=3600
CACHE_LOCK_TIMEOUT=10

# ─── Anti-Detection ────────────────────────────────────
MIN_DELAY_SECONDS=1.0
MAX_DELAY_SECONDS=3.0
ACCOUNT_COOLDOWN_SECONDS=300

# ─── Retry ──────────────────────────────────────────────
MAX_RETRIES=3
RETRY_BASE_DELAY=1.0

# ─── Rate Limiting ─────────────────────────────────────
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60

# ─── Sessions ──────────────────────────────────────────
SESSION_STORAGE_DIR=sessions/storage

# ─── Queues ─────────────────────────────────────────────
QUEUE_MAX_LENGTH=1000

# ─── Circuit Breaker ──────────────────────────────────
CIRCUIT_BREAKER_FAILURE_THRESHOLD=10
CIRCUIT_BREAKER_WINDOW_SECONDS=60
CIRCUIT_BREAKER_RECOVERY_SECONDS=30

# ─── Job State ─────────────────────────────────────────
JOB_RESULT_TTL_SECONDS=3600
JOB_DEDUP_TTL_SECONDS=300

# ─── Platform Config ──────────────────────────────────
PLATFORM_CONFIG_PATH=platform_config.yml

# ─── Security (REQUIRED IN PRODUCTION) ─────────────────
# Fernet key for encrypting account credentials at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# For zero-downtime rotation use CREDENTIAL_ENCRYPTION_KEYS=<new>,<old> instead.
CREDENTIAL_ENCRYPTION_KEY=
# CREDENTIAL_ENCRYPTION_KEYS=

# HMAC key for signing pagination cursors. Without this, every restart
# invalidates outstanding cursors. Any high-entropy string (32+ bytes).
# Generate with: openssl rand -hex 32
CURSOR_SIGNING_KEY=
CURSOR_TTL_SECONDS=3600

# Bearer token gating /metrics. If unset, /metrics is denied to everyone.
# Generate with: openssl rand -hex 32
METRICS_AUTH_TOKEN=

# Bearer token gating /admin/* (account onboarding, DLQ inspection, job
# cancellation). Fail-closed when unset. MUST be different from
# METRICS_AUTH_TOKEN so a leaked metrics secret can't escalate to mutations.
# Generate with: openssl rand -hex 32
ADMIN_AUTH_TOKEN=

# ─── Worker (optional) ─────────────────────────────────
# Restrict a worker process to a single platform's queue.
# WORKER_PLATFORM=instagram

# ─── Logging ────────────────────────────────────────────
LOG_LEVEL=INFO
